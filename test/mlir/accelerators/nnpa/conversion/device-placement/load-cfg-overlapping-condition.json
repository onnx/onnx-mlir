        }
      }
    },
    {
      "pattern": {
        "match": {
          "node_type": "onnx.Sigmoid",
          "onnx_node_name": "Sigmoid_0"
        },
        "rewrite": {
          "device": "nnpa"
        }
      }
    },
    {
      "pattern": {
        "match": {
          "node_type": "onnx.Relu",
          "onnx_node_name": "Relu_1"
        },
        "rewrite": {
          "device": "nnpa"
        }
      }
    }
  ]
}
